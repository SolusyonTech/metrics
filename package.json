{
  "name": "@solusyon/metrics",
  "version": "0.1.4",
  "description": "Metrics library for Node.js APIs.",
  "keywords": [
    "metrics",
    "observability",
    "telemetry"
  ],
  "homepage": "https://github.com/SolusyonTech/metrics#readme",
  "bugs": {
    "url": "https://github.com/SolusyonTech/metrics/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SolusyonTech/metrics.git"
  },
  "license": "MIT",
  "author": "Anderson Joel de Souza",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && mv dist-cjs/index.js dist/index.cjs && rm -rf dist-cjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "assertion-error": "^2.0.1",
    "cac": "^6.7.14",
    "chai": "^5.3.3",
    "check-error": "^2.1.3",
    "debug": "^4.4.3",
    "deep-eql": "^5.0.2",
    "es-module-lexer": "^1.7.0",
    "esbuild": "^0.27.7",
    "estree-walker": "^3.0.3",
    "expect-type": "^1.3.0",
    "fdir": "^6.5.0",
    "js-tokens": "^9.0.1",
    "loupe": "^3.2.1",
    "magic-string": "^0.30.21",
    "ms": "^2.1.3",
    "nanoid": "^3.3.11",
    "pathe": "^2.0.3",
    "pathval": "^2.0.1",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.10",
    "rollup": "^4.60.1",
    "siginfo": "^2.0.0",
    "source-map-js": "^1.2.1",
    "stackback": "^0.0.2",
    "std-env": "^3.10.0",
    "strip-literal": "^3.1.0",
    "tinybench": "^2.9.0",
    "tinyexec": "^0.3.2",
    "tinyglobby": "^0.2.16",
    "tinypool": "^1.1.1",
    "tinyrainbow": "^2.0.0",
    "tinyspy": "^4.0.4",
    "undici-types": "^7.19.2",
    "vite": "^7.3.2",
    "vite-node": "^3.2.4",
    "why-is-node-running": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=9"
  },
  "publishConfig": {
    "access": "public"
  },
  "module": "./dist/index.js",
  "sideEffects": false
}
